# Copy to `.env` (or `.env.local`) in the repo root and fill in values.
# `.env` and `.env.local` are gitignored — never commit real secrets.
#
# Load before bootRun, for example:
#   ./scripts/dev/run-with-env.sh
# or:
#   set -a && source .env && set +a && ./gradlew bootRun
#
# Spring maps these names to application.properties (relaxed binding).

# PostgreSQL (local defaults match application.properties)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/rhododendra
SPRING_DATASOURCE_USERNAME=rhododendra
SPRING_DATASOURCE_PASSWORD=change-me

# OAuth2 (optional locally unless testing sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
